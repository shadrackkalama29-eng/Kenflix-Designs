            color: #38bdf8;
            font-size: 14px;
            font-weight: 700;
            display: flex;
            align-items: center;
            gap: 8px;
            transition: all 0.3s ease;
        }
        .back-home-link:hover { opacity: 0.8; }

        /* Upload Button styling from image */
        .upload-btn {
            background-color: #f97316;
            color: white;
            padding: 10px 24px;
            border-radius: 9999px;
            font-weight: 800;
            display: inline-flex;
            align-items: center;
            gap: 10px;
            transition: transform 0.2s ease;
        }
        .upload-btn:hover { transform: scale(1.05); }

        .doc-card {
            background: rgba(15, 23, 42, 0.4);
            backdrop-filter: blur(12px);
            border: 1px solid rgba(255, 255, 255, 0.05);
            border-radius: 2rem;
            transition: all 0.4s ease;
            position: relative;
        }

        .most-downloaded {
            border: 2px solid #f97316 !important;
            box-shadow: 0 0 20px rgba(249, 115, 22, 0.2);
            animation: pulse-stroke 2s infinite;
        }

        @keyframes pulse-stroke {
            0% { box-shadow: 0 0 5px rgba(249, 115, 22, 0.2); }
            50% { box-shadow: 0 0 20px rgba(249, 115, 22, 0.5); }
            100% { box-shadow: 0 0 5px rgba(249, 115, 22, 0.2); }
