    <script>
        lucide.createIcons();
        document.getElementById('footer-year').textContent = new Date().getFullYear();

        function accessAdmin() { if (prompt("Security Code:") === "29") toggleUpload(); }
        function toggleUpload() { document.getElementById('uploadModal').classList.toggle('hidden'); }
        function updateFileName() { const f = document.getElementById('pdfFile').files[0]; if(f) document.getElementById('fileStatus').innerText = f.name; }

        function showListView() { document.getElementById('main-view').classList.add('hidden'); document.getElementById('list-view').classList.remove('hidden'); renderList(); }
        function showGridView() { document.getElementById('list-view').classList.add('hidden'); document.getElementById('main-view').classList.remove('hidden'); }

        function savePdfFromPc() {
            const title = document.getElementById('docTitle').value;
            const file = document.getElementById('pdfFile').files[0];
            const desc = document.getElementById('docDesc').value;
            if (!title || !file) return alert("Fill required fields");

            const reader = new FileReader();
            reader.onload = function(e) {
                const doc = { id: Date.now(), title, data: e.target.result, desc, downloads: 0 };
                let vault = JSON.parse(localStorage.getItem('kenflix_v6') || '[]');
                vault.unshift(doc);
                localStorage.setItem('kenflix_v6', JSON.stringify(vault));
                toggleUpload();
                renderVault();
            };
            reader.readAsDataURL(file);
        }

        function renderVault() {
            const grid = document.getElementById('resource-grid');
            const docs = JSON.parse(localStorage.getItem('kenflix_v6') || '[]');
            
            const maxDown = docs.length > 0 ? Math.max(...docs.map(d => d.downloads || 0)) : 0;
            const mostPopularId = (maxDown > 0) ? docs.find(d => d.downloads === maxDown).id : null;

            const featured = docs.slice(0, 6);
            if (docs.length > 6) document.getElementById('read-more-container').classList.remove('hidden');

            grid.innerHTML = featured.map(doc => `
                <div class="doc-card p-10 flex flex-col h-full ${doc.id === mostPopularId ? 'most-downloaded' : ''}">
                    ${doc.id === mostPopularId ? '<span class="absolute top-4 right-6 text-[8px] font-black text-brand-orange tracking-widest uppercase">Most Popular</span>' : ''}
                    <div class="w-12 h-12 bg-sky-accent/10 rounded-xl flex items-center justify-center text-sky-accent mb-8"><i data-lucide="file-text"></i></div>
                    <h3 class="text-xl font-black text-white mb-4 uppercase leading-tight">${doc.title}</h3>
                    <div class="mt-auto flex items-center gap-6 pt-8 border-t border-white/5">
                        <button onclick="openViewer('${doc.id}')" class="text-[10px] font-black text-sky-accent uppercase tracking-widest transition hover:text-white">Read Online</button>
                        <button onclick="downloadPdf('${doc.id}')" class="text-[10px] font-black text-brand-orange uppercase tracking-widest transition hover:text-white">Download</button>
                        <button onclick="removeDoc(${doc.id})" class="ml-auto text-gray-700 hover:text-red-500"><i data-lucide="trash-2" class="w-4 h-4"></i></button>
                    </div>
                </div>
            `).join('');
            lucide.createIcons();
        }

        function renderList() {
            const list = document.getElementById('resource-list');
            const docs = JSON.parse(localStorage.getItem('kenflix_v6') || '[]');
            list.innerHTML = docs.map(doc => `
                <div class="p-6 border-b border-white/5 flex flex-col md:flex-row justify-between items-center gap-4 hover:bg-white/5 transition">
                    <span class="text-white font-bold uppercase text-xs tracking-tight">${doc.title}</span>
                    <div class="flex gap-6 items-center">
                        <button onclick="openViewer('${doc.id}')" class="text-[10px] font-black text-sky-accent uppercase tracking-widest">Read Online</button>
                        <button onclick="downloadPdf('${doc.id}')" class="text-[10px] font-black text-brand-orange uppercase tracking-widest">Download</button>
                        <button onclick="removeDoc(${doc.id})" class="text-gray-700 hover:text-red-500"><i data-lucide="trash-2" class="w-4 h-4"></i></button>
                    </div>
                </div>
            `).join('');
            lucide.createIcons();
        }

        function openViewer(id) {
            const docs = JSON.parse(localStorage.getItem('kenflix_v6') || '[]');
            const doc = docs.find(d => d.id == id);
            document.getElementById('viewingTitle').innerText = doc.title;
            document.getElementById('viewingDesc').innerText = doc.desc || 'Internal Repository document.';
            document.getElementById('pdfFrame').src = doc.data;
            document.getElementById('dlBtnOverlay').onclick = () => downloadPdf(id);
            document.getElementById('pdfOverlay').classList.remove('hidden');
        }

        function downloadPdf(id) {
            let docs = JSON.parse(localStorage.getItem('kenflix_v6') || '[]');
            const docIdx = docs.findIndex(d => d.id == id);
            docs[docIdx].downloads = (docs[docIdx].downloads || 0) + 1;
            localStorage.setItem('kenflix_v6', JSON.stringify(docs));
            
            const a = document.createElement('a');
            a.href = docs[docIdx].data;
            a.download = docs[docIdx].title + ".pdf";
            a.click();
            renderVault();
        }

        function closeViewer() { document.getElementById('pdfOverlay').classList.add('hidden'); document.getElementById('pdfFrame').src = ''; }
        function removeDoc(id) { if (prompt("Security Code:") === "29") { let vault = JSON.parse(localStorage.getItem('kenflix_v6') || '[]'); vault = vault.filter(d => d.id !== id); localStorage.setItem('kenflix_v6', JSON.stringify(vault)); renderVault(); renderList(); } }
        
        window.onload = renderVault;
    </script>
